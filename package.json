{
	"name": "@rationallyprime/morphe",
	"version": "0.1.0",
	"type": "module",
	"packageManager": "bun@1.3.11",
	"description": "Morphe — a stratified adaptive-UI core. Phase 0 keystone.",
	"repository": {
		"type": "git",
		"url": "https://github.com/RationallyPrime/morphe.git"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"PACKAGING.md",
		"README.md",
		"CONTEXT.md",
		"CONTRACT.md",
		"VISION.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./components": {
			"types": "./dist/components.d.ts",
			"svelte": "./dist/components.js",
			"default": "./dist/components.js"
		},
		"./tokens": {
			"types": "./dist/tokens/index.d.ts",
			"svelte": "./dist/tokens/index.js",
			"default": "./dist/tokens/index.js"
		},
		"./styles.css": "./dist/styles.css",
		"./tokens/scales.css": "./dist/tokens/scales.css",
		"./tokens/intents.css": "./dist/tokens/intents.css",
		"./package.json": "./package.json"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"package": "svelte-package",
		"pack:verify": "bun scripts/pack-verify.ts",
		"registry:verify": "MORPHE_VERIFY_REGISTRY=1 bun scripts/pack-verify.ts",
		"prepack": "bun run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome check --write .",
		"codegen": "orval --config ./orval.config.ts",
		"embed": "bun scripts/embed-corpus.ts",
		"plates": "bun scripts/derive-plates.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.8.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/node": "^25.9.2",
		"@tanstack/svelte-query": "^6.1.34",
		"orval": "^8.15.0",
		"sharp": "^0.34.5",
		"svelte": "^5.1.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.6.0",
		"vite": "^5.4.0",
		"vitest": "^2.1.0",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@tanstack/svelte-query": "^6",
		"svelte": "^5",
		"zod": "^4"
	},
	"dependencies": {
		"esm-env": "^1.2.2"
	}
}
