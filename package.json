{
	"name": "@rationallyprime/morphe",
	"version": "0.4.1",
	"type": "module",
	"packageManager": "bun@1.3.11",
	"description": "Morphe — a stratified adaptive-UI core. Phase 0 keystone.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/RationallyPrime/morphe.git"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist",
		"schema",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"PACKAGING.md",
		"README.md",
		"CONTEXT.md",
		"CONTRACT.md",
		"VISION.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./components": {
			"types": "./dist/components.d.ts",
			"svelte": "./dist/components.js",
			"default": "./dist/components.js"
		},
		"./artifacts": {
			"types": "./dist/artifacts.d.ts",
			"svelte": "./dist/artifacts.js",
			"default": "./dist/artifacts.js"
		},
		"./tokens": {
			"types": "./dist/tokens/index.d.ts",
			"svelte": "./dist/tokens/index.js",
			"default": "./dist/tokens/index.js"
		},
		"./schemas/*": "./schema/*",
		"./styles.css": "./dist/styles.css",
		"./tokens/scales.css": "./dist/tokens/scales.css",
		"./tokens/intents.css": "./dist/tokens/intents.css",
		"./package.json": "./package.json"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"package": "svelte-package",
		"pack:verify": "bun scripts/pack-verify.ts",
		"registry:verify": "MORPHE_VERIFY_REGISTRY=1 bun scripts/pack-verify.ts",
		"plates": "bun scripts/derive-plates.ts",
		"prepack": "bun run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"viewer:dev": "cd viewer && vite dev",
		"viewer:build": "cd viewer && vite build",
		"viewer:build:node": "cd viewer && MORPHE_VIEWER_ADAPTER=node vite build",
		"viewer:check": "cd viewer && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"viewer:preview": "cd viewer && vite preview",
		"sync:all": "svelte-kit sync && cd viewer && svelte-kit sync",
		"test": "bun run sync:all && vitest run && vitest run --config vitest.dom.config.ts",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome check --write .",
		"demo": "vite dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@fontsource/fragment-mono": "^5.2.8",
		"@fontsource/hanken-grotesk": "^5.2.8",
		"@fontsource/spectral": "^5.2.8",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.8.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tanstack/svelte-query": "^6.1.34",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.9",
		"@types/node": "^25.9.2",
		"jsdom": "^27.3.0",
		"material-symbols": "^0.45.5",
		"sharp": "^0.35.3",
		"svelte": "^5.1.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.6.0",
		"vite": "^5.4.0",
		"vitest": "^2.1.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@tanstack/svelte-query": "^6",
		"svelte": "^5",
		"zod": "^4"
	},
	"dependencies": {
		"esm-env": "^1.2.2"
	}
}
