    "FAQSection": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "anyOf": [
            {
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "intent": {
          "anyOf": [
            {
              "enum": [
                "primary-action",
