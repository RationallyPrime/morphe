{
  "$defs": {
    "CTA": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Action Id"
        },
        "href": {
          "anyOf": [
            {
              "format": "uri",
              "maxLength": 2083,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Href"
        },
        "intent": {
          "default": "primary-action",
          "enum": [
            "primary-action",
            "neutral",
            "provenance",
            "evidence",
            "accession",
            "caution",
            "success",
            "info"
          ],
          "title": "Intent",
          "type": "string"
        },
        "label": {
          "maxLength": 48,
          "minLength": 2,
          "title": "Label",
          "type": "string"
        }
      },
      "required": [
        "label"
      ],
      "title": "CTA",
      "type": "object"
    },
    "CapabilityPageDraft": {
      "additionalProperties": false,
      "properties": {
        "audience": {
          "enum": [
            "founder",
            "operator",
            "cto",
            "cfo",
            "operations_lead",
            "developer",
            "buyer"
          ],
          "title": "Audience",
          "type": "string"
        },
        "cta": {
          "$ref": "#/$defs/CTA"
        },
        "hero": {
          "$ref": "#/$defs/HeroBlock"
        },
        "hero_variation": {
          "anyOf": [
            {
              "$ref": "#/$defs/HeroVariation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "morphe": {
          "$ref": "#/$defs/MorpheControls"
        },
        "proof_points": {
          "items": {
            "$ref": "#/$defs/ProofPoint"
          },
          "maxItems": 6,
          "title": "Proof Points",
          "type": "array"
        },
        "sections": {
          "items": {
            "discriminator": {
              "mapping": {
                "caseProof": "#/$defs/CaseProofSection",
                "faq": "#/$defs/FAQSection",
                "problemFrame": "#/$defs/ProblemFrameSection",
                "workflowMap": "#/$defs/WorkflowMapSection"
              },
              "propertyName": "kind"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ProblemFrameSection"
              },
              {
                "$ref": "#/$defs/WorkflowMapSection"
              },
              {
                "$ref": "#/$defs/CaseProofSection"
              },
              {
                "$ref": "#/$defs/FAQSection"
              }
            ]
          },
          "maxItems": 8,
          "minItems": 1,
          "title": "Sections",
          "type": "array"
        },
        "slug": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "title": "Slug",
          "type": "string"
        },
        "source_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 12,
          "title": "Source Ids",
          "type": "array"
        }
      },
      "required": [
        "slug",
        "audience",
        "hero",
        "sections",
        "cta"
      ],
      "title": "CapabilityPageDraft",
      "type": "object"
    },
    "CaseProofSection": {
