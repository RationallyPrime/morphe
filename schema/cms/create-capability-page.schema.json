            "gallery",
            "night",
            "icelandic-archive",
            "clinical",
            "reykjavik-registry",
            "timaeus",
            "ledger",
            "estate",
            "foundry"
          ],
          "title": "Dialect",
          "type": "string"
        },
        "emphasis": {
          "default": "normal",
          "enum": [
            "muted",
            "normal",
            "strong",
            "critical"
          ],
          "title": "Emphasis",
          "type": "string"
        },
        "primary_intent": {
          "default": "evidence",
          "enum": [
            "primary-action",
            "neutral",
            "provenance",
            "evidence",
            "accession",
            "caution",
            "success",
            "info"
          ],
          "title": "Primary Intent",
          "type": "string"
        },
        "surface": {
          "default": "base",
          "enum": [
            "base",
            "raised",
            "sunken"
          ],
          "title": "Surface",
          "type": "string"
        }
      },
      "title": "MorpheControls",
      "type": "object"
    },
