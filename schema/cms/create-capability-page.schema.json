        "before": {
          "maxLength": 240,
          "minLength": 8,
          "title": "Before",
          "type": "string"
        },
        "company_shape": {
          "anyOf": [
            {
              "maxLength": 120,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Company Shape"
        },
        "id": {
          "anyOf": [
            {
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "intent": {
          "anyOf": [
            {
              "enum": [
                "primary-action",
                "neutral",
                "provenance",
                "evidence",
                "accession",
                "caution",
                "success",
                "info"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intent"
        },
        "kind": {
          "const": "caseProof",
          "title": "Kind",
          "type": "string"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/Metric"
          },
          "maxItems": 4,
          "title": "Metrics",
          "type": "array"
        },
        "title": {
          "maxLength": 96,
          "minLength": 4,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "title",
        "before",
        "after"
      ],
      "title": "CaseProofSection",
      "type": "object"
    },
    "FAQItem": {
      "additionalProperties": false,
      "properties": {
        "answer": {
          "maxLength": 420,
          "minLength": 12,
          "title": "Answer",
          "type": "string"
        },
        "question": {
          "maxLength": 140,
          "minLength": 8,
